@using SAPPub.Web.Constants
@using SAPPub.Web.ViewComponents.VerticalNavigationCompareSecondary
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Compare Secondary";
}
<div class="govuk-grid-row">
    @await Component.InvokeAsync("VerticalNavigationCompareSecondary" ,
    new VerticalNavigationCompareSecondaryModel
    {
        ActivePage = RouteConstants.CompareSecondaryAcademicPerformancePupilProgressAndAttainment
    })

    <div class="govuk-grid-column-three-quarters">
        Looking at school performance data is one way to see how well a school is doing. 
        You should look at a range of information about a school before deciding if it's the right fit for your child.
    </div>
</div>