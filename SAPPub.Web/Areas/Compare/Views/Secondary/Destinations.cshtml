@model SAPPub.Web.Areas.Compare.ViewModels.Secondary.CompareDestinationsViewModel
@using SAPPub.Web.Constants
@using SAPPub.Web.ViewComponents.VerticalNavigationCompareSecondary

@{
    ViewData["Header"] = "Destinations after year 11";
    ViewData["SubHeader"] = PageTitleConstants.SecondarySchoolPageTitles.Destinations;
    ViewData["Title"] = $"Compare - {ViewData["SubHeader"]}";
}

<div class="govuk-grid-row">

    @await Component.InvokeAsync("VerticalNavigationCompareSecondary",
    new VerticalNavigationCompareSecondaryModel
    {
        URNs = Model.URNs,
        ActivePage = RouteConstants.CompareSecondaryDestinations
    })

    <div class="govuk-grid-column-three-quarters">
        <h1 class="govuk-heading-l">
            <span class="govuk-caption-l">@Constants.CompareYourSchools</span>
            @ViewData["Header"]
        </h1>

        <govuk-pagination id="destinations-pagination">
            <govuk-pagination-previous href="@Url.RouteUrl(RouteConstants.CompareSecondaryAcademicPerformanceEnglishAndMathsResults, new { urns = Model.URNs })">Academic performance: English and maths results</govuk-pagination-previous>
            <govuk-pagination-next href="@Url.RouteUrl(RouteConstants.CompareSecondaryNextSteps, new { urns = Model.URNs })">Next steps</govuk-pagination-next>
        </govuk-pagination>
    </div>
</div>