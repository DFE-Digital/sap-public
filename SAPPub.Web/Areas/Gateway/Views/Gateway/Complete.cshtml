@model GatewayWelcomeViewModel
@{
    ViewBag.Title = "School Profiles - signed up";
}


<div class="govuk-width-container">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">

            <h1 class="govuk-heading-xl">
                School Profiles - Signed up
            </h1>

            <p class="govuk-body">
                You've successfully signed up for the School Profiles service and can access it now.
            </p>

            <p class="govuk-body">
                We'll also email you a link so you can access the service later.
            </p>

            <p class="govuk-body">
                This link will be valid for 7 days.
            </p>

            <p class="govuk-body">
                Check your spam or junk folder if you cannot find the email.
            </p>

            <govuk-button-link is-start-button="true" href="/">Start</govuk-button-link>
        </div>
    </div>
</div>
