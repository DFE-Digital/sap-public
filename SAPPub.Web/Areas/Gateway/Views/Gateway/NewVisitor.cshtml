@model SAPPub.Web.Areas.Gateway.ViewModels.GatewayNewUserViewModel

@{
    ViewBag.Title = "New Visitor";
    ViewBag.BackUrl = Url.Action("Welcome", "Gateway", new { id = Model.LocalAuthorityName });
}

<div class="govuk-width-container">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            @using (Html.BeginForm("NewVisitor", "Gateway", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(x => x.LocalAuthorityName)
                @Html.HiddenFor(x => x.LocalAuthorityId)

                <govuk-input name="EmailAddress" spellcheck="false" value="@Html.ValueFor(x => x.EmailAddress)">
                    <govuk-input-label is-page-heading="true" class="govuk-label--l" for="EmailAddress">Enter your email address</govuk-input-label>
                    @if (ViewData.ModelState[Html.NameFor(x => x.EmailAddress)]?.Errors.Count() > 0)
                    {
                        <govuk-input-error-message for="EmailAddress"> @Html.ValidationMessageFor(m => m.EmailAddress)</govuk-input-error-message>
                    }


                </govuk-input>

                <govuk-radios name="@Html.NameFor(x => x.AcceptCookies)">
                    <govuk-radios-fieldset>
                        <govuk-radios-fieldset-legend is-page-heading="false" class="govuk-fieldset__legend--l">
                            Do you want to accept analytics cookies?
                        </govuk-radios-fieldset-legend>

                        <govuk-radios-hint>
                            Accepting analytics cookies helps us to understand how you use the service and helps us to find and fix problems.
                        </govuk-radios-hint>

                        @if (ViewData.ModelState[Html.NameFor(x => x.AcceptCookies)]?.Errors.Count() > 0)
                        {
                            <govuk-radios-error-message for="@Html.NameFor(x => x.AcceptCookies)"> @Html.ValidationMessageFor(m => m.AcceptCookies)</govuk-radios-error-message>
                        }

                        @if (Model.AcceptCookies == "true")
                        {
                            <govuk-radios-item checked="true" value="true">Yes</govuk-radios-item>
                            <govuk-radios-item value="false">No</govuk-radios-item>
                        }
                        else if (Model.AcceptCookies == "false")
                        {
                            <govuk-radios-item value="true">Yes</govuk-radios-item>
                            <govuk-radios-item checked="true" value="false">No</govuk-radios-item>
                        }
                        else
                        {
                            <govuk-radios-item value="true">Yes</govuk-radios-item>
                            <govuk-radios-item value="false">No</govuk-radios-item>
                        }

                    </govuk-radios-fieldset>
                </govuk-radios>

                <govuk-button type="submit">Confirm</govuk-button>

            }
        </div>
    </div>
</div>