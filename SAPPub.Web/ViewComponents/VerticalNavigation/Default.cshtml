@model SAPPub.Web.ViewComponents.VerticalNavigation.VerticalNavigationModel
@using SAPPub.Web.Constants
@using SAPPub.Web.Helpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@if (Model != null)
{
    var routeAttributes = new Dictionary<string, string> { { RouteConstants.URN, Model.URN }, { RouteConstants.SchoolName, Model.SchoolNameClean } };

    <div class="govuk-grid-column-one-quarter">
        <nav class="moj-side-navigation" aria-label="Side navigation">
            <ul class="moj-side-navigation__list">
                <li class="moj-side-navigation__item  @(Model.ActivePage == RouteConstants.SecondaryAboutSchool ? "moj-side-navigation__item--active" : "")">
                    <a asp-route="@RouteConstants.SecondaryAboutSchool" asp-all-route-data="routeAttributes">
                        @if (Model.IsKS5)
                        {
                            <text>About the school or college</text>
                        }
                        else
                        {
                            <text>About the school</text>
                        }

                    </a>
                </li>

                @if (Model.IsKS2 || Model.IsKS4)
                {
                    <li class="moj-side-navigation__item  @(Model.ActivePage == RouteConstants.SecondaryAdmissions ? "moj-side-navigation__item--active" : "")">
                        <a asp-route="@RouteConstants.SecondaryAdmissions" asp-all-route-data="routeAttributes">Admissions</a>
                    </li>
                }

                @if (Model.IsKS2 || Model.IsKS4)
                {
                    <li class="moj-side-navigation__item  @(Model.ActivePage == RouteConstants.SecondaryCurriculumAndExtraCurricularActivities ? "moj-side-navigation__item--active" : "")">
                        <a asp-route="@RouteConstants.SecondaryCurriculumAndExtraCurricularActivities" asp-all-route-data="routeAttributes">Curriculum and extra-curricular activities</a>
                    </li>
                }

                @if (Model.IsKS2 || Model.IsKS4)
                {
                    <li class="moj-side-navigation__item  @(Model.ActivePage == RouteConstants.SecondaryAttendance ? "moj-side-navigation__item--active" : "")">
                        <a asp-route="@RouteConstants.SecondaryAttendance" asp-all-route-data="routeAttributes">Attendance</a>
                    </li>
                }

                @if (Model.IsKS4)
                {
                    <li class="moj-side-navigation__item  @(new List<string> { RouteConstants.SecondaryAcademicPerformanceAttainmentAndProgress, RouteConstants.SecondaryAcademicPerformanceEnglishAndMathsResults, RouteConstants.SecondaryAcademicPerformanceSubjectsEntered }.Contains(Model.ActivePage) ? " moj-side-navigation__item--active" : "") ">
                        <a asp-route="@RouteConstants.SecondaryAcademicPerformanceAttainmentAndProgress" asp-all-route-data="routeAttributes">Secondary academic performance</a>
                    </li>
                }
                @if (Model.IsKS5)
                {
                    <li class="moj-side-navigation__item  @(new List<string> { RouteConstants.KS5AcademicPerformanceLevel3, RouteConstants.KS5AcademicPerformanceLevel2, RouteConstants.KS5AcademicPerformanceEnglishMaths, RouteConstants.KS5AcademicPerformanceSubjectsEntered }.Contains(Model.ActivePage) ? " moj-side-navigation__item--active" : "") ">
                        <a asp-route="@RouteConstants.KS5AcademicPerformanceRoot" asp-all-route-data="routeAttributes">16 to 19 academic performance</a>
                    </li>
                }
                @if (Model.IsKS4 || Model.IsKS5)
                {
                    <li class="moj-side-navigation__item  @(Model.ActivePage == RouteConstants.DestinationsRoot ? "moj-side-navigation__item--active" : "")">
                        <a asp-route="@RouteConstants.SecondaryDestinations" asp-all-route-data="routeAttributes">Destinations</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
