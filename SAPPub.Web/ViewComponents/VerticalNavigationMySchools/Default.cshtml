@model SAPPub.Web.ViewComponents.VerticalNavigationMySchools.VerticalNavigationMySchoolsModel
@using SAPPub.Web.Constants
@using SAPPub.Web.Helpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@if (Model != null)
{
    <div class="govuk-grid-column-one-quarter">
        <nav class="moj-side-navigation" aria-label="Side navigation">
            <ul class="moj-side-navigation__list">
                <li class="moj-side-navigation__item  @(Model.ActivePage == RouteConstants.MySchoolsList ? "moj-side-navigation__item--active" : "")">
                    <a asp-route="@RouteConstants.MySchoolsList">@($"Secondary schools ({Model.SchoolCount})")</a>
                </li>
            </ul>
        </nav>
    </div>
}
