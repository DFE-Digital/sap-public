@model SAPPub.Web.Models.Search.SearchResultsViewModel

<govuk-input input-class="govuk-input govuk-!-width-two-thirds" input-placeholder="Search by keyword" for=@Model.NameSearchTerm data-testid="searchByNameInput">
    <govuk-input-label is-page-heading="false" class="govuk-label--s" id="school-name">School name</govuk-input-label>
    <govuk-input-hint>For example, St Joseph's secondary school</govuk-input-hint>
</govuk-input>
<govuk-input input-class="govuk-input govuk-!-width-two-thirds" input-placeholder="Search by postcode" for=@Model.LocationSearchTerm data-testid="searchByLocationInput">
    <govuk-input-label is-page-heading="false" class="govuk-label--s" id="location">Postcode</govuk-input-label>
    <govuk-input-hint>For example, LS28 8EU</govuk-input-hint>
</govuk-input>
<govuk-select for="@Model.Miles">
    <govuk-select-item value="1" selected="@Model.Miles==1">1</govuk-select-item>
    <govuk-select-item value="3" selected="@Model.Miles==3">3</govuk-select-item>
    <govuk-select-item value="5" selected="@Model.Miles==5">5</govuk-select-item>
</govuk-select>
<govuk-button id="search" type="submit">Search</govuk-button>
