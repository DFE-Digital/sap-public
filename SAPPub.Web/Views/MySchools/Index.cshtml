@using SAPPub.Core.Enums
@using SAPPub.Web.ViewComponents.VerticalNavigationMySchools
@model SAPPub.Web.Models.MySchools.MySchoolsListViewModel


@{
    ViewData["Title"] = "My schools list";
    ViewData["Header"] = "Secondary schools";
}

<h1>@ViewData["Title"]</h1>
<p class="govuk-hint">Choose which schools you want to compare. You can select up to 6 schools.</p>

<div class="govuk-grid-row">
    @await Component.InvokeAsync("VerticalNavigationMySchools",
        new VerticalNavigationMySchoolsModel
        {
            ActivePage = RouteConstants.MySchoolsView,
            SchoolCount = Model.MySchools.Count
        })

    <div class="govuk-grid-column-three-quarters">
        <h2 class="govuk-heading-l govuk-!-margin-bottom-4">@ViewData["Header"]</h2>
        <form method="post" asp-controller="CompareSecondary" asp-action="Index">
            <div class="govuk-checkboxes" data-testid="my-schools-list">
                @foreach (var modelItem in Model.MySchools)
                {
                    <div class="govuk-checkboxes__item">
                        <input class="govuk-checkboxes__input" type="checkbox" name="selectedEstablishments" value="@modelItem.Urn">
                        <label class="govuk-label govuk-checkboxes__label"><strong>@modelItem.SchoolName</strong></label>
                        <div class="govuk-checkboxes__hint">
                            <div>@modelItem.Address</div>
                            @if (modelItem.EstablishmentStatus == EstablishmentStatus.Closed)
                            {
                                <strong class="govuk-tag tag--block">
                                    @(modelItem.ClosedDate.IsAvailable ? $"Closed in {modelItem.ClosedDate.DisplayText(d => d.ToString("MMMM yyyy"))}" : "Closed")
                                </strong>
                            }
                        </div>
                    </div>
                    <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible" />
                }
            </div>
            <govuk-button id="compare" type="submit">Compare selected schools</govuk-button>
        </form>
    </div>
</div>
