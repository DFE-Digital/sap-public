@{
    ViewData["Title"] = "My schools list";
}

<span class="govuk-caption-l">@ViewData["Title"]</span>
<h1 class="govuk-heading-l">Add schools to compare</h1>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        You can create a 'My schools' list of schools or colleges to compare.
        Search for a school or college using a name or location, then use 'Add to My schools list' to add your first school or college to the list.
        <a asp-route="@RouteConstants.Search" role="button" draggable="false" class="govuk-button govuk-!-margin-top-6 govuk-!-margin-bottom-6" data-module="govuk-button">Search for schools and colleges to compare</a>
    </div>
</div>
