@model SAPPub.Web.Models.SecondarySchool.AcademicPerformanceAttainmentAndProgressViewModel;
@using SAPPub.Web.ViewComponents.VerticalNavigation

@{
    ViewData["Header"] = "Academic performance";
    ViewData["SubHeader"] = PageTitleConstants.SecondarySchoolPageTitles.AttainmentAndProgress;
    ViewData["Title"] = $"{Model.SchoolName} - {ViewData["SubHeader"]}";
}

<div class="govuk-grid-row">
    @await Component.InvokeAsync("VerticalNavigation",
    new VerticalNavigationModel
    {
        URN = Model.URN,
        SchoolName = Model.SchoolName,
        ActivePage = RouteConstants.SecondaryAcademicPerformanceAttainmentAndProgress
    })

    <div class="govuk-grid-column-three-quarters">
        <span id="school-name-caption" class="govuk-caption-xl">@Model.SchoolName</span>
        <h1 class="govuk-heading-xl">@ViewData["Header"]</h1>
        <p class="govuk-body">
            Looking at school performance data is one way to see how well a school is doing.
            You should look at a range of information about a school before deciding if it’s the right fit for your child.
        </p>

        <nav id="sub-navigation-academic-performance" class="moj-sub-navigation" aria-label="Sub navigation">
            <ul class="moj-sub-navigation__list">
                <li class="moj-sub-navigation__item">
                    <a class="moj-sub-navigation__link" aria-current="page" asp-route="@RouteConstants.SecondaryAcademicPerformanceAttainmentAndProgress" asp-all-route-data="@Model.RouteAttributes">@ViewData["SubHeader"]</a>
                </li>
                <li class="moj-sub-navigation__item">
                    <a class="moj-sub-navigation__link" asp-route="@RouteConstants.SecondaryAcademicPerformanceEnglishAndMathsResults" asp-all-route-data="@Model.RouteAttributes">@PageTitleConstants.SecondarySchoolPageTitles.EnglishAndMathsResults</a>
                </li>
                <li class="moj-sub-navigation__item">
                    <a class="moj-sub-navigation__link" asp-route="@RouteConstants.SecondaryAcademicPerformanceSubjectsEntered" asp-all-route-data="@Model.RouteAttributes">@PageTitleConstants.SecondarySchoolPageTitles.SubjectsEntered</a>
                </li>
            </ul>
        </nav>

        <h2 class="govuk-heading-l">Pupil @ViewData["SubHeader"]?.ToString()?.ToLower()</h2>

        <p class="govuk-body" data-testid="academic-year-info">@Model.AcademicYearInfoParagraph</p>

        <form method="get" asp-action="AcademicPerformanceAttainmentAndProgress" asp-controller="SecondarySchool">
            <div id="filterSection" class="select-filter">
                <label for="academicYearSelector" class="govuk-label govuk-!-font-weight-bold">Choose the academic year you want to see results for</label>
                <select id="academicYearSelector" class="govuk-select" asp-for="SelectedAcademicYear" asp-items="Model.AcademicYearsSelectList"></select>
                <govuk-button type="submit">Show results</govuk-button>
            </div>
        </form>

        <h3 class="govuk-heading-m">Progress 8</h3>

        <p class="govuk-body">
            Progress 8 measures a school’s performance. It shows how much progress pupils make from the end of primary school (KS2) to the end of secondary school (KS4), across 8 qualifications.
        </p>

        <ul class="govuk-list govuk-list--bullet">
            <li>
                A score of zero means pupils made about the same progress as similar pupils across England.
            </li>
            <li>
                A positive score means pupils made more progress than similar pupils across England.
            </li>
            <li>
                A negative score means pupils made less progress than similar pupils across England.
            </li>
        </ul>

        <govuk-details id="details-progress8">
            <govuk-details-summary>
                Find out more about Progress 8 confidence intervals
            </govuk-details-summary>
            <govuk-details-text>
                <p class="govuk-body">
                    Progress 8 scores are influenced by both the school and their pupils. It is difficult to determine how much of the progress score is due to the school and how much is due to the pupils themselves. Confidence intervals reflect this uncertainty.
                </p>

                <p class="govuk-body">
                    If the confidence intervals for two schools overlap, it means we cannot be sure that one school’s Progress 8 score is better than the other.
                </p>

                <p class="govuk-body">
                    The greater the number of pupils, the smaller the range of the confidence interval. Smaller schools have larger confidence intervals because fewer pupils are included, so the score is more affected by the performance of individual pupils.  
                </p>

                <p class="govuk-body">
                    A school is above average if its Progress 8 score is above 0 and the entire confidence interval is above 0.
                </p>
                <p class="govuk-body">
                    A school is below average if its Progress 8 score is below 0 and the entire confidence interval is below 0.
                </p>

                <p class="govuk-body">
                    Read more about how confidence intervals are used in the <a class="govuk-link govuk-link--no-visited-state" href="https://www.gov.uk/government/publications/progress-8-school-performance-measure" rel="nofollow noreferrer" target="_blank">secondary accountability measures guidance</a>.
                </p>


            </govuk-details-text>
        </govuk-details>

        @if (Model.ShowProgress8NotAvailableInfo)
        {
            <div class="custom-card" data-testid="progress8-custom-card">
                <div class="info__icon"></div>
                <div class="custom-card__content">
                    <p class="govuk-body">
                        There are no Progress 8 scores available for the academic years 2024 to 2025 and 2025 to 2026. This is because there is no KS2 baseline available to calculate secondary progress measures for these years due to COVID-19 disruption.
                    </p>
                </div>
            </div>
        }
        else
        {
            <div class="custom-card" data-testid="progress8-establishment-card">
                <div class="assignment__icon"></div>
                <div class="custom-card__content">
                    <p class="govuk-body">
                        Pupils at this school score @Model.EstablishmentProgress8Score.
                        @if (Model.EstablishmentProgress8BandingContextDescription.IsAvailable)
                        {
                            <span>@Model.EstablishmentProgress8BandingContextDescription.DisplayText()</span>
                        }
                    </p>
                    <p class="govuk-body">
                        The confidence interval is @Model.EstablishmentProgress8CILower to @Model.EstablishmentProgress8CIUpper.
                    </p>
                </div>
            </div>

            <govuk-details id="pupil-details-progress8">
                <govuk-details-summary>
                    Pupils included in this measure
                </govuk-details-summary>
                <govuk-details-text>
                    <p class="govuk-body">
                        @Model.EstablishmentProgress8TotalPupils out of @Model.EstablishmentTotalPupils pupils were included in this measure.
                    </p>
                </govuk-details-text>
            </govuk-details>

            <div class="custom-card" data-testid="progress8-localauthority-card">
                <div class="custom-card__content">
                    <p class="govuk-body">
                        The local authority average is @Model.LocalAuthorityProgress8Score.
                    </p>
                </div>
                <div class="bar-chart__icon"></div>
            </div>
        }

        <h3 class="govuk-heading-m">Attainment 8</h3>

        <p class="govuk-body">
            Attainment 8 is used to assess a pupil’s average achievement across their 8 best GCSE-level subjects.
        </p>

        <govuk-details id="details-attainment8">
            <govuk-details-summary>
                Find out more about Attainment 8
            </govuk-details-summary>
            <govuk-details-text>
                <p class="govuk-body">
                    The 8 subjects that are used in Attainment 8 are split into 3 groups:
                </p>

                <ul class="govuk-list govuk-list--bullet">
                    <li>
                        English and maths, which are both double-weighted
                    </li>
                    <li>
                        other subjects including sciences, geography, history and languages
                    </li>
                    <li>
                        any other approved GCSEs or vocational qualifications
                    </li>
                </ul>

                <p class="govuk-body">
                    Each GCSE grade is given a point score (for example grade 9 = 9 points, grade 8 = 8 points, and so on).
                    The scores from the best 8 subjects (with English and maths counting twice) are added together to give the Attainment 8 score.
                </p>

                <p class="govuk-body">
                    If a student scores high grades across these subjects, their Attainment 8 score will be higher.  The maximum score a pupil can have is 90.
                </p>
            </govuk-details-text>
        </govuk-details>

        @if (Model.ShowAttainment8Info)
        {
            <div class="custom-card" data-testid="attainment8-establishment-card">
                <div class="assignment__icon"></div>
                <div class="custom-card__content">
                    <p class="govuk-body">
                        The Attainment 8 score for this school is @($"{Model.EstablishmentAttainment8Score:0.0}").
                    </p>
                    @if (Model.EstablishmentAttainment8ScoreContextDescription.IsAvailable)
                    {
                        <p class="govuk-body">
                            @Model.EstablishmentAttainment8ScoreContextDescription.DisplayText()
                        </p>
                    }
                </div>
            </div>

            <div class="custom-card" data-testid="attainment8-localauthority-and-national-card">
                <div class="custom-card__content">
                    @if (Model.LocalAuthorityAttainment8ScoreContextDescription.IsAvailable)
                    {
                        <p class="govuk-body">
                            @Model.LocalAuthorityAttainment8ScoreContextDescription.DisplayText()
                        </p>
                    }
                    @if (Model.EnglandAttainment8ScoreContextDescription.IsAvailable)
                    {
                        <p class="govuk-body">
                            @Model.EnglandAttainment8ScoreContextDescription.DisplayText()
                        </p>
                    }
                </div>
                <div class="bar-chart__icon"></div>
            </div>
        }
        else
        {
            <div class="custom-card" data-testid="attainment8-no-establishment-data-card">
                <div class="info__icon"></div>
                <div class="custom-card__content">
                    <p class="govuk-body">
                        There is no Attainment 8 data for this school.
                    </p>
                </div>
            </div>
        }

        <govuk-pagination id="academic-performance-attainment-and-progress-pagination">
            <govuk-pagination-previous asp-route="@RouteConstants.SecondaryAttendance" asp-all-route-data="@Model.RouteAttributes">Attendance</govuk-pagination-previous>
            <govuk-pagination-next asp-route="@RouteConstants.SecondaryAcademicPerformanceEnglishAndMathsResults" asp-all-route-data="@Model.RouteAttributes">Academic performance: English and maths results</govuk-pagination-next>
        </govuk-pagination>
    </div>
</div>
